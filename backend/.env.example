APP_NAME=Image Generation Workflow API
APP_VERSION=0.1.0
API_V1_PREFIX=/v1

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=imgwf_mvp
JOB_TTL_SECONDS=604800
IDEMPOTENCY_TTL_SECONDS=86400

# Set this in production. If empty, callback signature verification is disabled.
CALLBACKS_SECRET=change_me_to_a_random_32_byte_secret
CALLBACK_CLOCK_SKEW_SECONDS=300
CALLBACK_NONCE_TTL_SECONDS=600
CALLBACK_EVENT_DEDUP_TTL_SECONDS=86400

UPLOAD_ROOT_DIR=storage
UPLOAD_IMAGE_SUBDIR=images
GENERATED_IMAGE_SUBDIR=generated
UPLOAD_IMAGE_MAX_BYTES=15728640
GENERATED_IMAGE_MAX_BYTES=20971520
GENERATED_IMAGE_FETCH_TIMEOUT_SECONDS=20
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
MIRROR_GENERATED_OUTPUTS=true
PUBLIC_BASE_URL=
